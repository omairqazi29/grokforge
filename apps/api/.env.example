# xAI API Key — get one at https://console.x.ai
# Set this to enable real Grok. Leave empty for mock provider.
XAI_API_KEY=

# Model to use (default: grok-4-1-fast)
XAI_MODEL=grok-4-1-fast

# Database URL (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./grokforge.db

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000"]
